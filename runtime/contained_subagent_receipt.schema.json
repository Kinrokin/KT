{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt.fp0.contained_subagent_receipt.v2",
  "type": "object",
  "required": [
    "schema_id",
    "subagent_id",
    "canonical_write_attempted",
    "canonical_write_allowed",
    "claim_expansion_attempted",
    "sandbox_exit_status"
  ],
  "properties": {
    "schema_id": {
      "const": "kt.fp0.contained_subagent_receipt.v2"
    },
    "subagent_id": {
      "type": "string"
    },
    "canonical_write_attempted": {
      "type": "boolean"
    },
    "canonical_write_allowed": {
      "const": false
    },
    "claim_expansion_attempted": {
      "type": "boolean"
    },
    "sandbox_exit_status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "QUARANTINED"
      ]
    }
  }
}
