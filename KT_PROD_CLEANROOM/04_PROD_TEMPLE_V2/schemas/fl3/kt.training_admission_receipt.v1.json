{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Training Admission Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "admission_receipt_id",
    "lane_id",
    "decision",
    "reason_codes",
    "job_ref",
    "job_sha256",
    "law_bundle_hash",
    "failure_taxonomy_id",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.training_admission_receipt.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "admission_receipt_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "lane_id": { "type": "string" },
    "decision": { "enum": ["PASS", "FAIL_CLOSED"] },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "job_ref": { "type": "string" },
    "job_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "law_bundle_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "failure_taxonomy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

