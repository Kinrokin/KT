{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "kt.work_order.mrt1_e2e.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "intent",
    "mode",
    "constraints",
    "preconditions",
    "phase_A_batteries",
    "phase_B_negative_live_checks",
    "phase_C1_mrt1_canary",
    "phase_C2_tournament_canary",
    "phase_D_determinism_check",
    "final_outputs"
  ],
  "properties": {
    "schema_id": { "const": "kt.work_order.mrt1_e2e.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },

    "intent": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "mode": { "type": "string", "minLength": 1, "maxLength": 128 },

    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "law_bundle_required",
        "canonical_lane_required",
        "attestation_mode_required",
        "fail_closed_on_any_violation",
        "no_repo_mutation_except_receipts"
      ],
      "properties": {
        "law_bundle_required": { "type": "boolean" },
        "canonical_lane_required": { "type": "boolean" },
        "attestation_mode_required": { "type": "string", "minLength": 1, "maxLength": 32 },
        "fail_closed_on_any_violation": { "type": "boolean" },
        "no_repo_mutation_except_receipts": { "type": "boolean" }
      }
    },

    "preconditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env_vars_required", "env_assertions", "repo_state"],
      "properties": {
        "env_vars_required": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
        "env_assertions": { "type": "object", "additionalProperties": { "type": "string" } },
        "repo_state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["git_clean_required", "law_bundle_hash_required"],
          "properties": {
            "git_clean_required": { "type": "boolean" },
            "law_bundle_hash_required": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          }
        }
      }
    },

    "phase_A_batteries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "commands", "pass_criteria"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "commands": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 2048 } },
        "pass_criteria": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },

    "phase_B_negative_live_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "tests"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "command", "expected"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 256 },
              "command": { "type": "string", "minLength": 1, "maxLength": 4096 },
              "expected": { "type": "string", "minLength": 1, "maxLength": 64 }
            }
          }
        }
      }
    },

    "phase_C1_mrt1_canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "job", "artifacts_expected", "output_root", "pass_criteria"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "job": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runner", "args"],
          "properties": {
            "runner": { "type": "string", "minLength": 1, "maxLength": 256 },
            "args": {
              "type": "object",
              "additionalProperties": false,
              "required": ["job_path", "organ_contract"],
              "properties": {
                "job_path": { "type": "string", "minLength": 1, "maxLength": 1024 },
                "organ_contract": { "type": "string", "minLength": 1, "maxLength": 1024 }
              }
            }
          }
        },
        "artifacts_expected": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 256 } },
        "output_root": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "pass_criteria": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },

    "phase_C2_tournament_canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "tournament", "artifacts_expected", "pass_criteria"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "tournament": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runner", "suites", "entrants_min", "entrants_max"],
          "properties": {
            "runner": { "type": "string", "minLength": 1, "maxLength": 256 },
            "suites": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
            "entrants_min": { "type": "integer", "minimum": 1, "maximum": 32 },
            "entrants_max": { "type": "integer", "minimum": 1, "maximum": 32 }
          }
        },
        "artifacts_expected": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 256 } },
        "pass_criteria": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },

    "phase_D_determinism_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "procedure", "pass_criteria"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "procedure": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 4096 } },
        "pass_criteria": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },

    "final_outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipts_required", "verdict"],
      "properties": {
        "receipts_required": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 512 } },
        "verdict": {
          "type": "object",
          "additionalProperties": false,
          "required": ["on_pass", "on_fail"],
          "properties": {
            "on_pass": { "type": "string", "minLength": 1, "maxLength": 128 },
            "on_fail": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        }
      }
    }
  }
}

