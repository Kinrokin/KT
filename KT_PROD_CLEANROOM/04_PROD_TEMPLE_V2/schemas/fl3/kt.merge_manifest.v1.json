{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Merge Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "merge_manifest_id",
    "base_model_id",
    "role_tag",
    "merge_method",
    "parents",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.merge_manifest.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "merge_manifest_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "base_model_id": { "type": "string" },
    "role_tag": { "type": "string" },
    "merge_method": { "type": "string" },
    "parents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["adapter_root_hash", "adapter_id", "adapter_version"],
        "properties": {
          "adapter_root_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "adapter_id": { "type": "string" },
          "adapter_version": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

