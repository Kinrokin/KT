{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Audit Pattern Cluster v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "cluster_id",
    "reason_code",
    "event_ids",
    "count",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.audit_pattern_cluster.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "cluster_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "reason_code": { "type": "string", "minLength": 1, "maxLength": 128 },
    "event_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" } },
    "count": { "type": "integer", "minimum": 1, "maximum": 1000000000 },
    "notes": { "type": ["string", "null"], "maxLength": 8192 },
    "created_at": { "type": "string" }
  }
}

