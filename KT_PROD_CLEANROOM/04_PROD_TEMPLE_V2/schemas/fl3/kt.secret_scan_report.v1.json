{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Secret Scan Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "report_id",
    "status",
    "scanner_version",
    "patterns_version",
    "findings",
    "report_hash",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.secret_scan_report.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "report_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "status": { "enum": ["PASS", "FAIL", "ERROR"] },
    "scanner_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "patterns_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "lane_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "notes": { "type": ["string", "null"], "maxLength": 8192 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "path_rel",
          "reason",
          "confidence",
          "snippet_redacted",
          "snippet_sha256"
        ],
        "properties": {
          "finding_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "path_rel": { "type": "string", "minLength": 1, "maxLength": 2048 },
          "line": { "type": "integer", "minimum": 1 },
          "column": { "type": "integer", "minimum": 1 },
          "reason": {
            "enum": [
              "REGEX",
              "DECODED_REGEX",
              "HIGH_ENTROPY",
              "ENCODED_HIGH_ENTROPY",
              "READ_ERROR"
            ]
          },
          "confidence": { "enum": ["HIGH", "MEDIUM", "LOW"] },
          "pattern_id": { "type": ["string", "null"], "maxLength": 128 },
          "snippet_redacted": { "type": "string", "maxLength": 256 },
          "snippet_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "report_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_at": { "type": "string" }
  }
}

