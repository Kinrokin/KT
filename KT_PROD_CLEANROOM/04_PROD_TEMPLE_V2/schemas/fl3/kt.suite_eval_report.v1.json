{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Suite Eval Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "suite_eval_report_id",
    "suite_outputs_id",
    "suite_definition_id",
    "validator_catalog_id",
    "axis_scoring_policy_id",
    "status",
    "case_results",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.suite_eval_report.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_eval_report_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_outputs_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_definition_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "validator_catalog_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "axis_scoring_policy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "status": { "type": "string", "enum": ["PASS", "FAIL"] },
    "case_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "passed", "validator_results"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "passed": { "type": "boolean" },
          "failed_validator_ids": { "type": "array", "items": { "type": "string" } },
          "validator_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["validator_id", "passed", "score"],
              "properties": {
                "validator_id": { "type": "string", "minLength": 1, "maxLength": 128 },
                "passed": { "type": "boolean" },
                "score": { "type": "number" },
                "notes": { "type": ["string", "null"] }
              }
            }
          },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

