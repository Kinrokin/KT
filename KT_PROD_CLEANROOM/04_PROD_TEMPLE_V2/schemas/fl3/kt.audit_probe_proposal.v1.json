{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Audit Probe Proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "proposal_id",
    "proposal_type",
    "title",
    "description",
    "reason_code",
    "evidence_event_ids",
    "requires_human_approval",
    "earliest_review_timestamp",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.audit_probe_proposal.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "proposal_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "proposal_type": { "enum": ["NEW_TEST", "NEW_DRILL", "NEW_PROBE"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 256 },
    "description": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "reason_code": { "type": "string", "minLength": 1, "maxLength": 128 },
    "evidence_event_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" } },
    "requires_human_approval": { "type": "boolean" },
    "earliest_review_timestamp": { "type": "string" },
    "created_at": { "type": "string" }
  }
}

