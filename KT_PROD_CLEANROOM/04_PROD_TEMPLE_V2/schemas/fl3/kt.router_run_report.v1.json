{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Router Run Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "router_run_report_id",
    "run_id",
    "router_policy_id",
    "router_demo_suite_id",
    "status",
    "case_receipts",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.router_run_report.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "router_run_report_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "router_policy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "router_demo_suite_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "status": { "type": "string", "enum": ["PASS", "FAIL"] },
    "case_receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "receipt_path", "receipt_sha256"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "receipt_path": { "type": "string", "minLength": 1, "maxLength": 512 },
          "receipt_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

