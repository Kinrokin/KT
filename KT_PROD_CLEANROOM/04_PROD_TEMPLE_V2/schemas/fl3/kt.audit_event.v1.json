{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Audit Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "event_id",
    "run_id",
    "lane_id",
    "event_kind",
    "severity",
    "reason_codes",
    "component",
    "summary",
    "evidence_paths",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.audit_event.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "event_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "lane_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "event_kind": { "type": "string", "minLength": 1, "maxLength": 64 },
    "severity": { "enum": ["INFO", "WARN", "FAIL", "FAIL_CLOSED", "CONTAMINATED"] },
    "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "component": { "type": "string", "minLength": 1, "maxLength": 128 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "evidence_paths": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 2048 } },
    "notes": { "type": ["string", "null"], "maxLength": 8192 },
    "created_at": { "type": "string" }
  }
}

