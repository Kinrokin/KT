{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Routing Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "routing_receipt_id",
    "run_id",
    "router_policy_id",
    "router_demo_suite_id",
    "case_id",
    "input_sha256",
    "domain_tag",
    "matched_keywords",
    "selected_adapter_ids",
    "required_adapter_ids",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.routing_receipt.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "routing_receipt_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "router_policy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "router_demo_suite_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "case_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "domain_tag": { "type": "string", "minLength": 1, "maxLength": 128 },
    "matched_keywords": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "selected_adapter_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "required_adapter_ids": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

