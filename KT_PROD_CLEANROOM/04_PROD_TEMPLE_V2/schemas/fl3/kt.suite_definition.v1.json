{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Suite Definition v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "suite_definition_id",
    "suite_id",
    "suite_version",
    "purpose",
    "validator_catalog_ref",
    "validator_catalog_id",
    "axis_scoring_policy_ref",
    "axis_scoring_policy_id",
    "cases",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.suite_definition.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_definition_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "suite_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "purpose": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "validator_catalog_ref": { "type": "string", "minLength": 1, "maxLength": 512 },
    "validator_catalog_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "axis_scoring_policy_ref": { "type": "string", "minLength": 1, "maxLength": 512 },
    "axis_scoring_policy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "domain_tag", "expected_behavior", "prompt", "validator_ids"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "domain_tag": { "type": "string", "minLength": 1, "maxLength": 128 },
          "expected_behavior": { "type": "string", "enum": ["COMPLY", "REFUSE", "CLARIFY"] },
          "prompt": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "validator_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
          "tags": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 64 } },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

