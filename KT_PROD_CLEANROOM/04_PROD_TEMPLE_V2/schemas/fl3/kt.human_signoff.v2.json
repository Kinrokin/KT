{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT FL3 Human Signoff v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "signoff_id",
    "attestation_mode",
    "key_id",
    "payload_hash",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.human_signoff.v2" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "signoff_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "attestation_mode": { "type": "string", "enum": ["SIMULATED", "HMAC", "PKI"] },
    "key_id": { "type": "string" },
    "payload_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "simulated_signature": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "hmac_signature": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "hmac_key_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "pki_signature_b64": { "type": "string" },
    "pki_cert_fingerprint_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_at": { "type": "string" }
  }
}

