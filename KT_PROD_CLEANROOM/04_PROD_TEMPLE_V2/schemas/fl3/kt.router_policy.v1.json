{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Router Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "router_policy_id",
    "policy_name",
    "policy_version",
    "match_strategy",
    "routes",
    "default_adapter_ids",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.router_policy.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "router_policy_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy_name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "policy_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "match_strategy": { "type": "string", "enum": ["KEYWORD_SUBSTRING_LEXICOGRAPHIC_MIN"] },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "domain_tag",
          "keywords",
          "adapter_ids",
          "required_adapter_ids"
        ],
        "properties": {
          "domain_tag": { "type": "string", "minLength": 1, "maxLength": 128 },
          "keywords": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
          "adapter_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
          "required_adapter_ids": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "default_adapter_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

