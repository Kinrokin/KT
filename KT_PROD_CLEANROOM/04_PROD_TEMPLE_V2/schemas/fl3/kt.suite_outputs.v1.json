{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Suite Outputs v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "suite_outputs_id",
    "base_model_id",
    "subject",
    "suite_id",
    "suite_root_hash",
    "decode_policy_id",
    "decode_cfg_hash",
    "outputs",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.suite_outputs.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_outputs_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "base_model_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_kind", "subject_id"],
      "properties": {
        "subject_kind": { "type": "string", "enum": ["BASE", "ADAPTER"] },
        "subject_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "adapter_root_hash": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "suite_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "suite_root_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "decode_policy_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "decode_cfg_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "output_text", "output_sha256"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "output_text": { "type": "string" },
          "output_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

