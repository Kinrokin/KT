{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Audit Intelligence Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "config_id",
    "min_cluster_size",
    "proposal_cooldown_hours",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.audit_intelligence_config.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "config_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "min_cluster_size": { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "proposal_cooldown_hours": { "type": "integer", "minimum": 0, "maximum": 87600 },
    "reason_code_allowlist": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "created_at": { "type": "string" }
  }
}

