{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Secret Scan Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "summary_id",
    "report_hash",
    "status",
    "total_findings",
    "high_confidence_findings",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.secret_scan_summary.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "summary_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "report_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "status": { "enum": ["PASS", "FAIL", "ERROR"] },
    "total_findings": { "type": "integer", "minimum": 0 },
    "high_confidence_findings": { "type": "integer", "minimum": 0 },
    "run_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "lane_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "created_at": { "type": "string" }
  }
}

