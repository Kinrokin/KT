{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Audit Event Index v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "index_id",
    "vault_root_rel",
    "entries",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.audit_event_index.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "index_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "vault_root_rel": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "entries": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "event_id"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 2048 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "event_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "created_at": { "type": "string" }
  }
}

