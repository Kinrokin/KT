{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Probe Synthesis Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "manifest_id",
    "vault_root_rel",
    "event_count",
    "min_support",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.probe_synthesis_manifest.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "manifest_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "vault_root_rel": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "event_count": { "type": "integer", "minimum": 0, "maximum": 1000000000 },
    "min_support": { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"], "maxLength": 8192 }
  }
}
