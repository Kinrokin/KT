{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT Router Demo Suite v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version_hash",
    "router_demo_suite_id",
    "suite_id",
    "suite_version",
    "purpose",
    "cases",
    "created_at"
  ],
  "properties": {
    "schema_id": { "const": "kt.router_demo_suite.v1" },
    "schema_version_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "router_demo_suite_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "suite_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "suite_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "purpose": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "input_text",
          "expected_domain_tag",
          "expected_adapter_ids"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "input_text": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "expected_domain_tag": { "type": "string", "minLength": 1, "maxLength": 128 },
          "expected_adapter_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "created_at": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}

