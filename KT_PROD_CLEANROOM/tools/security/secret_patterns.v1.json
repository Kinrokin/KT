{
  "schema_id": "kt.secret_patterns.v1",
  "version": "v1",
  "patterns": [
    {
      "pattern_id": "OPENAI_API_KEY",
      "confidence": "HIGH",
      "regex": "\\bsk-[A-Za-z0-9]{20,}\\b",
      "description": "OpenAI API key-like token"
    },
    {
      "pattern_id": "HUGGINGFACE_TOKEN",
      "confidence": "HIGH",
      "regex": "\\bhf_[A-Za-z0-9]{20,}\\b",
      "description": "Hugging Face token-like secret"
    },
    {
      "pattern_id": "AWS_ACCESS_KEY_ID",
      "confidence": "HIGH",
      "regex": "\\bAKIA[0-9A-Z]{16}\\b",
      "description": "AWS access key id-like token"
    },
    {
      "pattern_id": "GOOGLE_API_KEY",
      "confidence": "HIGH",
      "regex": "\\bAIza[0-9A-Za-z\\-_]{20,}\\b",
      "description": "Google API key-like token"
    },
    {
      "pattern_id": "PRIVATE_KEY_BLOCK",
      "confidence": "HIGH",
      "regex": "-----BEGIN (?:RSA |EC |OPENSSH )?PRIVATE KEY-----",
      "description": "Private key PEM header"
    }
  ],
  "allowlist": [
    {
      "allow_id": "SHA256_HEX",
      "regex": "\\b[0-9a-f]{64}\\b",
      "description": "sha256 hex digests (common in KT evidence)"
    },
    {
      "allow_id": "GIT_SHA1_HEX",
      "regex": "\\b[0-9a-f]{40}\\b",
      "description": "git sha1 digests"
    },
    {
      "allow_id": "SHA256_PREFIX",
      "regex": "\\bsha256:[0-9a-f]{64}\\b",
      "description": "sha256: prefixed digests"
    }
  ]
}

