<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>KT Delivery Dashboard — {{RUN_ID}}</title>
    <style>
      body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin: 24px; line-height: 1.4; }
      code { background: #f3f3f3; padding: 2px 4px; border-radius: 4px; }
      .card { border: 1px solid #ddd; border-radius: 10px; padding: 16px; margin: 12px 0; }
      .k { color: #555; font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; }
      .v { font-size: 14px; word-break: break-all; }
    </style>
  </head>
  <body>
    <h1>KT Delivery Dashboard</h1>
    <div class="card">
      <div class="k">Run ID</div>
      <div class="v"><code>{{RUN_ID}}</code></div>
    </div>
    <div class="card">
      <div class="k">Base Model</div>
      <div class="v"><code>{{BASE_MODEL_ID}}</code></div>
    </div>
    <div class="card">
      <div class="k">Bundle Root Hash</div>
      <div class="v"><code>{{BUNDLE_ROOT_HASH}}</code></div>
    </div>
    <div class="card">
      <div class="k">Secret Scan Result</div>
      <div class="v"><code>{{SECRET_SCAN_RESULT}}</code></div>
    </div>
    <p>See <code>reports/</code> for executive summary and technical report.</p>
  </body>
</html>

