{
  "$id": "kt.foundation_pack.evidence_ledger.schema.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "entry": {
      "additionalProperties": false,
      "properties": {
        "artifact_ref": {
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "claim_classes": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "evidence_class": {
          "type": "string"
        },
        "evidence_commit": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "evidence_id": {
          "type": "string"
        },
        "generated_utc": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "subject_commit": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "supersedes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "validator_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "evidence_id",
        "artifact_ref",
        "artifact_sha256",
        "evidence_class",
        "subject_commit",
        "evidence_commit",
        "claim_classes",
        "validator_refs",
        "generated_utc",
        "status",
        "supersedes"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "entries": {
      "items": {
        "$ref": "#/$defs/entry"
      },
      "type": "array"
    },
    "generated_utc": {
      "type": "string"
    },
    "ledger_id": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "ledger_id",
    "generated_utc",
    "entries"
  ],
  "title": "KT Evidence Ledger Schema",
  "type": "object"
}
