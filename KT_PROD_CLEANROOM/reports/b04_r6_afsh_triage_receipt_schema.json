    "triage_receipt_id",
    "top_level_verdict",
    "triage_subtype",
    "route_eligible",
    "selector_entry_authorized",
    "numeric_scores",
    "primary_reason_code",
    "trust_zone_tags",
    "evidence_tags",
    "risk_tags",
