{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt-codex://schemas/multiversal_fitness_record.schema.json",
  "title": "Multiversal Fitness Record (Temporal, Per-World Regions)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "artifact_id",
    "timestamp",
    "world_fitness",
    "temporal_lineage",
    "promotion_blocked",
    "block_reason_code",
    "determinism_fingerprint"
  ],
  "properties": {
    "schema_id": {
      "const": "kt.multiversal_fitness_record.v1"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-.]{1,127}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "world_fitness": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/world_fitness_entry"
      }
    },
    "temporal_lineage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lineage_event"
      }
    },
    "promotion_blocked": {
      "type": "boolean"
    },
    "block_reason_code": {
      "type": "string",
      "enum": [
        "UNRESOLVED_MULTIVERSAL_CONFLICT",
        "WORLD_REJECTED_AT_ADMISSION",
        "TERMINAL_CONFLICT",
        "COUNTER_PRESSURE_MISSING",
        "REGION_C_PRESENT",
        "TEMPORAL_INSTABILITY_DETECTED"
      ]
    },
    "determinism_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "world_fitness_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_id",
        "region"
      ],
      "properties": {
        "world_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{3,79}$"
        },
        "region": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C"
          ]
        }
      }
    },
    "lineage_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_id",
        "epoch",
        "region"
      ],
      "properties": {
        "world_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{3,79}$"
        },
        "epoch": {
          "type": "integer",
          "minimum": 0
        },
        "region": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C"
          ]
        }
      }
    }
  }
}

