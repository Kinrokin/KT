{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt-codex://schemas/conflict_event.schema.json",
  "title": "Conflict Event (Cross-Axis Conflict Metabolism)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "conflict_id",
    "timestamp",
    "axes",
    "suite_id",
    "measurement_basis_id",
    "measurements",
    "counter_pressure_refs",
    "disputed_claims",
    "trigger_context",
    "resolution_status",
    "admission",
    "determinism_fingerprint"
  ],
  "properties": {
    "schema_id": {
      "const": "kt.conflict_event.v1"
    },
    "conflict_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_\\-]{7,79}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "axes": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9][A-Z0-9_\\-]{1,63}$"
      }
    },
    "suite_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-.]{1,127}$"
    },
    "measurement_basis_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-\\.]{1,127}$"
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/measurement"
      }
    },
    "counter_pressure_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "disputed_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/disputed_claim"
      }
    },
    "trigger_context": {
      "$ref": "#/$defs/trigger_context"
    },
    "resolution_status": {
      "type": "string",
      "enum": [
        "OPEN",
        "RESOLVED_WITH_OVERRIDE",
        "BLOCKED_PENDING_EVIDENCE",
        "REJECTED_AT_ADMISSION",
        "ESCALATED_STALEMATE"
      ]
    },
    "admission": {
      "$ref": "#/$defs/admission"
    },
    "override_decision": {
      "$ref": "#/$defs/override_decision"
    },
    "stalemate": {
      "$ref": "#/$defs/stalemate"
    },
    "determinism_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resolution_status": {
            "const": "RESOLVED_WITH_OVERRIDE"
          }
        },
        "required": [
          "resolution_status"
        ]
      },
      "then": {
        "required": [
          "override_decision"
        ],
        "properties": {
          "admission": {
            "properties": {
              "admission_status": {
                "const": "ADMITTED"
              }
            },
            "required": [
              "admission_status"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_status": {
            "const": "ESCALATED_STALEMATE"
          }
        },
        "required": [
          "resolution_status"
        ]
      },
      "then": {
        "required": [
          "stalemate"
        ],
        "properties": {
          "admission": {
            "properties": {
              "admission_status": {
                "const": "ADMITTED"
              }
            },
            "required": [
              "admission_status"
            ]
          }
        },
        "not": {
          "required": [
            "override_decision"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_status": {
            "const": "REJECTED_AT_ADMISSION"
          }
        },
        "required": [
          "resolution_status"
        ]
      },
      "then": {
        "properties": {
          "admission": {
            "properties": {
              "admission_status": {
                "const": "REJECTED"
              }
            },
            "required": [
              "admission_status"
            ]
          }
        },
        "not": {
          "anyOf": [
            {
              "required": [
                "override_decision"
              ]
            },
            {
              "required": [
                "stalemate"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "admission": {
            "properties": {
              "admission_status": {
                "const": "ADMITTED"
              }
            },
            "required": [
              "admission_status"
            ]
          }
        },
        "required": [
          "admission"
        ]
      },
      "then": {
        "properties": {
          "counter_pressure_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_status": {
            "enum": [
              "OPEN",
              "BLOCKED_PENDING_EVIDENCE"
            ]
          }
        },
        "required": [
          "resolution_status"
        ]
      },
      "then": {
        "properties": {
          "admission": {
            "properties": {
              "admission_status": {
                "const": "ADMITTED"
              }
            },
            "required": [
              "admission_status"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "admission_status",
        "admission_timestamp",
        "gate_checks",
        "admitted_by"
      ],
      "properties": {
        "admission_status": {
          "type": "string",
          "enum": [
            "ADMITTED",
            "REJECTED"
          ]
        },
        "admission_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "gate_checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "measurement_basis_authorized",
            "counter_pressure_present",
            "axes_registered",
            "suite_admissible"
          ],
          "properties": {
            "measurement_basis_authorized": {
              "type": "boolean"
            },
            "counter_pressure_present": {
              "type": "boolean"
            },
            "axes_registered": {
              "type": "boolean"
            },
            "suite_admissible": {
              "type": "boolean"
            }
          }
        },
        "rejection_reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "MEASUREMENT_BASIS_UNAUTHORIZED",
              "COUNTER_PRESSURE_MISSING",
              "AXIS_UNREGISTERED",
              "SUITE_INADMISSIBLE"
            ]
          }
        },
        "admitted_by": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "actor_kind",
            "actor_id"
          ],
          "properties": {
            "actor_kind": {
              "type": "string",
              "enum": [
                "JUDGE_NODE0",
                "COUNCIL",
                "OPERATOR"
              ]
            },
            "actor_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-\\.]{0,127}$"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "admission_status": {
                "const": "REJECTED"
              }
            },
            "required": [
              "admission_status"
            ]
          },
          "then": {
            "required": [
              "rejection_reason_codes"
            ]
          }
        }
      ]
    },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha256",
        "path",
        "kind"
      ],
      "properties": {
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_./\\\\\\-]{0,240}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "json",
            "txt",
            "zip",
            "report",
            "receipt",
            "manifest",
            "other"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "law_citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "law_bundle_hash",
        "citation_kind",
        "citation_ref"
      ],
      "properties": {
        "law_bundle_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "citation_kind": {
          "type": "string",
          "enum": [
            "LAW_BUNDLE_CLAUSE",
            "POLICY_DOC",
            "SCHEMA_CONTRACT",
            "WORK_ORDER",
            "OTHER"
          ]
        },
        "citation_ref": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_./\\\\\\-]{0,240}$"
        },
        "citation_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "axis_id",
        "metric_id",
        "value",
        "unit",
        "direction",
        "pass_fail",
        "evidence_ref"
      ],
      "properties": {
        "axis_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{1,63}$"
        },
        "metric_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-\\.]{1,127}$"
        },
        "value": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": [
            "score",
            "ratio",
            "count",
            "seconds",
            "ms",
            "bytes",
            "usd",
            "bool"
          ]
        },
        "direction": {
          "type": "string",
          "enum": [
            "higher_is_better",
            "lower_is_better",
            "target_is_best"
          ]
        },
        "threshold": {
          "type": "number"
        },
        "pass_fail": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "INCONCLUSIVE"
          ]
        },
        "evidence_ref": {
          "$ref": "#/$defs/artifact_ref"
        }
      }
    },
    "disputed_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_class",
        "claimant_axis_id",
        "claim_basis",
        "claim_ref",
        "claim_summary_code",
        "severity",
        "disputed_by_axes"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{3,79}$"
        },
        "claim_class": {
          "type": "string",
          "enum": [
            "SAFETY",
            "COMPLIANCE",
            "PERFORMANCE",
            "DETERMINISM",
            "COST",
            "UX",
            "OTHER"
          ]
        },
        "claimant_axis_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{1,63}$"
        },
        "claim_basis": {
          "type": "string",
          "enum": [
            "MEASUREMENT",
            "POLICY",
            "EVIDENCE",
            "INTERPRETATION"
          ]
        },
        "claim_ref": {
          "$ref": "#/$defs/artifact_ref"
        },
        "claim_summary_code": {
          "type": "string",
          "enum": [
            "CONTRADICTS_MEASUREMENTS",
            "MEASUREMENT_DRIFT",
            "POLICY_VIOLATION",
            "EVIDENCE_MISSING",
            "SPEC_AMBIGUITY",
            "OTHER"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "disputed_by_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z0-9][A-Z0-9_\\-]{1,63}$"
          }
        }
      }
    },
    "trigger_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_kind",
        "trigger_ref",
        "lane"
      ],
      "properties": {
        "trigger_kind": {
          "type": "string",
          "enum": [
            "SUITE_EVAL",
            "TOURNAMENT",
            "CANARY",
            "RED_ASSAULT",
            "MANUAL_REVIEW",
            "OTHER"
          ]
        },
        "trigger_ref": {
          "$ref": "#/$defs/artifact_ref"
        },
        "lane": {
          "type": "string",
          "enum": [
            "ci_sim",
            "canonical_hmac",
            "unknown"
          ]
        }
      }
    },
    "stalemate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stalemate_reason_code",
        "law_citations",
        "escalation_target",
        "escalation_timestamp",
        "escalated_by"
      ],
      "properties": {
        "stalemate_reason_code": {
          "type": "string",
          "enum": [
            "LAW_PROHIBITS_OVERRIDE",
            "MEASUREMENT_NON_COMPARABLE",
            "SCOPE_UNDEFINED",
            "RISK_UNBOUNDED"
          ]
        },
        "law_citations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/law_citation"
          }
        },
        "escalation_target": {
          "type": "string",
          "enum": [
            "COUNCIL",
            "OPERATOR",
            "HALT"
          ]
        },
        "escalation_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "escalated_by": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "actor_kind",
            "actor_id"
          ],
          "properties": {
            "actor_kind": {
              "type": "string",
              "enum": [
                "JUDGE_NODE0",
                "COUNCIL",
                "OPERATOR"
              ]
            },
            "actor_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-\\.]{0,127}$"
            }
          }
        }
      }
    },
    "override_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "winning_axis",
        "override_reason_code",
        "law_citations",
        "determinism_fingerprint",
        "decision_timestamp",
        "decided_by"
      ],
      "properties": {
        "winning_axis": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{1,63}$"
        },
        "override_reason_code": {
          "type": "string",
          "enum": [
            "SAFETY_BLOCK",
            "COMPLIANCE_BLOCK",
            "DETERMINISM_BLOCK",
            "EVIDENCE_INSUFFICIENT",
            "MEASUREMENT_INVALID",
            "SCOPE_OVERRIDE"
          ]
        },
        "law_citations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/law_citation"
          }
        },
        "determinism_fingerprint": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "decision_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "decided_by": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "actor_kind",
            "actor_id"
          ],
          "properties": {
            "actor_kind": {
              "type": "string",
              "enum": [
                "JUDGE_NODE0",
                "COUNCIL",
                "OPERATOR"
              ]
            },
            "actor_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-\\.]{0,127}$"
            }
          }
        }
      }
    }
  }
}
