{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt.suite_revocation_record.schema.v1",
  "title": "KT Suite Revocation Record (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "revocation_id",
    "suite_id",
    "timestamp_utc",
    "reason_codes",
    "evidence_refs"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "kt.suite_revocation_record.v1" },
    "revocation_id": { "type": "string", "pattern": "^REVOCATION_[A-Z0-9_]+$" },
    "suite_id": { "type": "string", "pattern": "^SUITE_[A-Z0-9_]+$" },
    "timestamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^RC_[A-Z0-9_]+_[0-9]{4}$" },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}

