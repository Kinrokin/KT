{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt.suite_registry_index.schema.v1",
  "title": "KT Suite Registry Index (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "registry_id",
    "version",
    "entries"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "kt.suite_registry_index.v1" },
    "registry_id": { "type": "string", "pattern": "^KT_SUITE_REGISTRY_[A-Z0-9_]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "entries": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "suite_id",
          "suite_version",
          "admission_record_sha256",
          "status",
          "timestamp_utc"
        ],
        "properties": {
          "suite_id": { "type": "string", "pattern": "^SUITE_[A-Z0-9_]+$" },
          "suite_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
          "admission_record_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "status": { "type": "string", "enum": ["ADMITTED", "REVOKED"] },
          "timestamp_utc": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
          },
          "revocation_record_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}

