{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt.suite_admission_record.schema.v1",
  "title": "KT Suite Admission Record (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "suite_id",
    "suite_version",
    "pack_sha256",
    "manifest_sha256",
    "validator_contract_ids",
    "world_set_ids",
    "thresholds_id",
    "canonicalization_profile_id",
    "determinism_fingerprint",
    "operator_sig",
    "registry_sig",
    "timestamp_utc"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "kt.suite_admission_record.v1" },
    "suite_id": { "type": "string", "pattern": "^SUITE_[A-Z0-9_]+$" },
    "suite_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "pack_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "validator_contract_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "world_set_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "thresholds_id": { "type": "string", "minLength": 1 },
    "canonicalization_profile_id": { "type": "string", "minLength": 1 },
    "determinism_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs"],
      "properties": {
        "inputs": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "operator_sig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sig_type", "signer_id", "signature"],
      "properties": {
        "sig_type": { "type": "string", "enum": ["HMAC_SHA256"] },
        "signer_id": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "registry_sig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sig_type", "signer_id", "signature"],
      "properties": {
        "sig_type": { "type": "string", "enum": ["HMAC_SHA256"] },
        "signer_id": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "timestamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}

