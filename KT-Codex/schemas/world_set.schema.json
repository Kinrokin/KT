{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kt.world_set.schema.v2",
  "title": "KT World Set (v2)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "world_set_id",
    "version",
    "canonicalization_profile_id",
    "invariants_ref",
    "worlds"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "kt.world_set.v2"
    },
    "world_set_id": {
      "type": "string",
      "pattern": "^KT_WORLD_SET_[A-Z0-9_]+_V[0-9]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "canonicalization_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "invariants_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_type", "ref"],
      "properties": {
        "ref_type": { "type": "string", "enum": ["FILE_SHA256", "MANIFEST_SHA256", "LABEL"] },
        "ref": { "type": "string", "minLength": 1 }
      }
    },
    "worlds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "world_definition.schema.json" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_type", "ref"],
            "properties": {
              "ref_type": { "type": "string", "enum": ["WORLD_ID", "FILE_SHA256"] },
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    }
  }
}

