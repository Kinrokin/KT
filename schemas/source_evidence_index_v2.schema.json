{
  "$id": "https://kt.local/schemas/kt.livewire.source_evidence_index.v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_utc": {
      "format": "date-time",
      "type": "string"
    },
    "law": {
      "minLength": 1,
      "type": "string"
    },
    "build_subject_head": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "merged_main_head": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "observed_main": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "origin_main_discovery_status": {
      "enum": [
        "FOUND",
        "UNKNOWN"
      ]
    },
    "schema_id": {
      "const": "kt.livewire.source_evidence_index.v2"
    },
    "starting_main_head": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "sources": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "authority_class": {
            "enum": [
              "LIVE_CANONICAL",
              "CURRENT_HEAD_RECEIPT",
              "IMMUTABLE_MEASURED_EVIDENCE",
              "RECOVERED_REPACKAGED_EVIDENCE",
              "EXTERNAL_POINTER",
              "NONCONTROLLING_CONTEXT"
            ]
          },
          "bytes": {
            "minimum": 0,
            "type": "integer"
          },
          "controlling": {
            "type": "boolean"
          },
          "external_locator": {
            "oneOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "head": {
            "oneOf": [
              {
                "pattern": "^[0-9a-f]{40}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "packet_relative_path": {
            "oneOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "repo_path": {
            "oneOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "source_id": {
            "minLength": 1,
            "type": "string"
          },
          "transport_identity_status": {
            "enum": [
              "BYTE_IDENTICAL",
              "REPACKAGED_NOT_BYTE_IDENTICAL",
              "NOT_APPLICABLE",
              "UNKNOWN_BLOCKED"
            ]
          }
        },
        "required": [
          "source_id",
          "authority_class",
          "packet_relative_path",
          "repo_path",
          "external_locator",
          "head",
          "sha256",
          "bytes",
          "transport_identity_status",
          "controlling"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "validated_at_head": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "schema_id",
    "observed_main",
    "starting_main_head",
    "build_subject_head",
    "validated_at_head",
    "merged_main_head",
    "origin_main_discovery_status",
    "created_utc",
    "law",
    "sources"
  ],
  "title": "KT Livewire Source Evidence Index V2",
  "type": "object"
}
