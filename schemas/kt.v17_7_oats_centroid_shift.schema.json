      "const": "kt.v17_7.oats_centroid_shift_receipt.v1"
    },
    "alpha": {
      "type": "number"
    },
    "beta": {
      "type": "number"
    },
    "feature_names": {
      "type": "array",
      "minItems": 1
    },
    "routes": {
      "type": "object",
      "minProperties": 3
    },
    "oracle_correctness_used_as_input_feature": {
      "const": false
    },
    "claim_ceiling_preserved": {
      "const": true
    }
  }
}
