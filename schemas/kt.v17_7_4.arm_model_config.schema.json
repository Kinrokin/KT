{
  "$id": "kt.v17_7_4.arm_model_config.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "arms": {
      "items": {
        "properties": {
          "adapter_binding_status": {
            "type": "string"
          },
          "adapter_hf_repo": {
            "type": "string"
          },
          "adapter_path": {
            "type": "string"
          },
          "adapter_required_for_real_authority": {
            "type": "boolean"
          },
          "adapter_sha256_optional": {
            "type": "string"
          },
          "arm_id": {
            "type": "string"
          },
          "arm_kind": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "max_new_tokens": {
            "minimum": 1,
            "type": "integer"
          },
          "model_repo_or_base": {
            "type": "string"
          },
          "prompt_template_id": {
            "type": "string"
          },
          "scoring_method": {
            "type": "string"
          }
        },
        "required": [
          "arm_id",
          "model_repo_or_base",
          "adapter_hf_repo",
          "adapter_path",
          "adapter_sha256_optional",
          "enabled",
          "prompt_template_id",
          "scoring_method",
          "max_new_tokens"
        ],
        "type": "object"
      },
      "minItems": 5,
      "type": "array"
    },
    "adapter_root_default": {
      "type": "string"
    },
    "adapter_root_env": {
      "type": "string"
    },
    "base_model_repo": {
      "minLength": 1,
      "type": "string"
    },
    "batch_size": {
      "minimum": 1,
      "type": "integer"
    },
    "bnb_4bit_compute_dtype": {
      "enum": [
        "float16",
        "bfloat16",
        "float32"
      ],
      "type": "string"
    },
    "bnb_4bit_quant_type": {
      "enum": [
        "nf4",
        "fp4"
      ],
      "type": "string"
    },
    "bnb_4bit_use_double_quant": {
      "type": "boolean"
    },
    "device_map": {
      "type": "string"
    },
    "generation_seed": {
      "type": "integer"
    },
    "load_in_4bit": {
      "type": "boolean"
    },
    "low_cpu_mem_usage": {
      "type": "boolean"
    },
    "max_new_tokens": {
      "minimum": 1,
      "type": "integer"
    },
    "torch_dtype": {
      "type": "string"
    },
    "trust_remote_code": {
      "type": "boolean"
    },
    "config_profile": {
      "type": "string"
    },
    "real_arm_authority_requested": {
      "type": "boolean"
    },
    "smoke_config": {
      "type": "boolean"
    }
  },
  "required": [
    "base_model_repo",
    "load_in_4bit",
    "torch_dtype",
    "max_new_tokens",
    "batch_size",
    "device_map",
    "generation_seed",
    "arms"
  ],
  "type": "object"
}
