{
  "$id": "https://kt.local/schemas/kt.derivation_envelope.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "build_execution_id": {
      "minLength": 1,
      "type": "string"
    },
    "build_host_fingerprint_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "envelope_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "generated_from_head": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "generator_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "payload_path": {
      "minLength": 1,
      "type": "string"
    },
    "payload_schema_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_id": {
      "const": "kt.derivation_envelope.v1"
    },
    "source_set_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "payload_schema_id",
    "payload_path",
    "payload_sha256",
    "generator_sha256",
    "source_set_sha256",
    "generated_from_head",
    "generated_at",
    "build_execution_id",
    "build_host_fingerprint_sha256",
    "envelope_sha256"
  ],
  "title": "KT Nondeterministic Derivation Envelope V1",
  "type": "object"
}
