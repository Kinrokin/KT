{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KT V17.7 Policy Grid Search Scorecard",
  "type": "object",
  "required": [
    "schema_id",
    "grid_size",
    "best_config",
    "best_scorecard",
    "top_results",
    "claim_ceiling_preserved"
  ],
  "properties": {
    "schema_id": {
      "const": "kt.v17_7.policy_grid_search_scorecard.v1"
    },
    "grid_size": {
      "type": "integer",
      "minimum": 1
    },
    "best_config": {
      "type": "object"
    },
    "best_scorecard": {
      "type": "object"
    },
    "top_results": {
      "type": "array",
      "minItems": 1
    },
    "claim_ceiling_preserved": {
      "const": true
    }
  }
}
